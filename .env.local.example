# ── Backend API ───────────────────────────────────────────────────────────────
# The Node.js/MongoDB backend base URL (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:5000

# ── Auth ──────────────────────────────────────────────────────────────────────
# The access token is stored in React state (AuthContext).
# The refresh token is stored in an HTTP-only cookie set by the backend.
# No secrets needed here — cookies are handled server-side.

# ── Cloudinary (optional — only needed if you handle uploads on the frontend) ─
# By default, image uploads go through the backend (/api/teams, /api/players)
# which handles Cloudinary. If you want direct frontend uploads, add these:
# NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
# NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your_unsigned_preset
