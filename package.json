{
  "name": "cricket-elite-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "dev:admin": "turbo dev --filter=admin",
    "dev:match-center": "turbo dev --filter=match-center",
    "build:admin": "turbo build --filter=admin",
    "build:match-center": "turbo build --filter=match-center"
  },
  "devDependencies": {
    "turbo": "^2.0.0"
  },
  "packageManager": "npm@10.0.0"
}
